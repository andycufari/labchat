#!/usr/bin/env bash
# labchat вЂ” a live two-way text chat between two machines on a LAN, riding ssh.
#
# Same command on both ends:
#   вЂў On your laptop:  `labchat`        вЂ” connects to the remote over an ssh
#                                          tunnel (loopback-only, encrypted).
#   вЂў On the box:      `labchat here`   вЂ” joins the same chat locally (no ssh).
#
# Both sides share an append-only "wall" file (~/.labchat-wall on the box).
# Type a line, it appears on the other end. `/quit` or Ctrl-C leaves.
#
#   labchat              connect from a client (drives the remote over ssh)
#   labchat here         join from the box itself (local, no ssh/tunnel)
#   labchat serve        just start the local listener and exit (no chat)
#   labchat stop         kill the local listener (use on the box)
#   labchat status       is the listener up? (local if `here`, else remote)
#   labchat say "text"   one-shot: push a line to the wall, no session
#   labchat tail         one-shot: print the recent wall and exit
#
# Config via env: LABCHAT_HOST (ssh alias/host of the box, client mode),
# LABCHAT_PORT, LABCHAT_NAME (tag for your lines). Needs `socat` on the box and
# `nc` on the client. The listener does not survive a reboot вЂ” just reconnect.

set -euo pipefail

HOST="${LABCHAT_HOST:-cm64labs}"   # ssh alias/host of the box (client mode)
PORT="${LABCHAT_PORT:-9999}"        # loopback port on the box (and local fwd)
NAME="${LABCHAT_NAME:-$(hostname -s 2>/dev/null || echo me)}"  # tag for your lines
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HELPER_SRC="$SELF_DIR/labchatd.sh"
WALL="$HOME/.labchat-wall"

# в”Ђв”Ђ helper: the per-connection handler the listener runs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# In `here`/`serve` mode it's already next to us; in client mode we scp it over.
helper_local() { printf '%s' "$HELPER_SRC"; }

# в”Ђв”Ђ starting a listener в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Start a socat listener bound to loopback that runs labchatd.sh per connection.
# Used locally (here/serve) and remotely (client mode, over ssh). Idempotent.
listener_cmd() {
  cat <<'SH'
set -e
PORT="$1"; HELPER="$2"
if ss -tlnH "sport = :$PORT" 2>/dev/null | grep -q LISTEN; then
  echo "listener already up on :$PORT"; exit 0
fi
chmod +x "$HELPER" 2>/dev/null || true
# fork = multiple connections; loopback-only; setsid to outlive this shell.
setsid socat TCP-LISTEN:"$PORT",bind=127.0.0.1,reuseaddr,fork \
  EXEC:"$HELPER",pty,stderr >/dev/null 2>&1 < /dev/null &
sleep 0.3
echo "listener up on 127.0.0.1:$PORT"
SH
}

start_local_listener() {
  bash -c "$(listener_cmd)" _ "$PORT" "$(helper_local)"
}

start_remote_listener() {
  scp -q "$HELPER_SRC" "$HOST:.labchatd.sh"
  ssh "$HOST" bash -s -- "$PORT" '$HOME/.labchatd.sh' <<<"$(listener_cmd)"
}

# в”Ђв”Ђ message display helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Parse incoming line: "[hostname] message" в†’ display with formatting.
# Uses dim for self (в†’), bold for others (в†ђ), with timestamps.
display_message() {
  local msg="$1"
  [[ -z "$msg" ]] && return

  if [[ "$msg" =~ ^\[([^]]+)\]\ (.+)$ ]]; then
    local sender="${BASH_REMATCH[1]}"
    local text="${BASH_REMATCH[2]}"
    local ts
    ts=$(date +%H:%M:%S)
    if [[ "$sender" == "$NAME" ]]; then
      printf '\e[2m[%s] в†’ [%s] %s\e[0m\n' "$ts" "$sender" "$text"
    else
      printf '\e[2m[%s]\e[0m \e[1mв†ђ [%s]\e[0m %s\n' "$ts" "$sender" "$text"
    fi
  else
    printf '\e[2mв†’ %s\e[0m\n' "$msg"
  fi
}

# в”Ђв”Ђ chat loop: proper dual I/O with readline в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# $1 = port to nc into (already reachable locally)
# $2 = ssh tunnel PID (optional, for cleanup)
chat_loop() {
  local p="$1"
  local tunnel_pid="${2:-}"
  local send_fifo="" recv_fifo=""
  local nc_pid=""
  local cleanup_done=0

  # Create two FIFOs: one for sending to remote, one for receiving
  send_fifo=$(mktemp -u /tmp/labchat-send-XXXXXX)
  recv_fifo=$(mktemp -u /tmp/labchat-recv-XXXXXX)
  mkfifo "$send_fifo" "$recv_fifo"

  # Cleanup handler (idempotent)
  cleanup() {
    [ "$cleanup_done" = "1" ] && return
    cleanup_done=1
    kill "$nc_pid" 2>/dev/null || true
    kill "$tunnel_pid" 2>/dev/null || true
    wait "$nc_pid" 2>/dev/null || true
    rm -f "$send_fifo" "$recv_fifo"
  }
  trap cleanup INT TERM EXIT

  echo "в”Ђв”Ђ labchat: type to chat В· /quit or Ctrl-C to leave в”Ђв”Ђ"

  # Open FIFOs as file descriptors
  exec 3<"$recv_fifo"   # fd 3: read incoming messages from nc
  exec 4>"$send_fifo"   # fd 4: write outgoing messages to nc

  # Start nc in background: reads user input from send_fifo, writes incoming to recv_fifo
  nc 127.0.0.1 "$p" < "$send_fifo" > "$recv_fifo" 2>/dev/null &
  nc_pid=$!

  # Wait for nc to connect (flushes history from tail -f)
  sleep 0.5
  if ! kill -0 "$nc_pid" 2>/dev/null; then
    echo "error: could not connect to 127.0.0.1:$p" >&2
    exec 3<&- 4>&- 2>/dev/null
    rm -f "$send_fifo" "$recv_fifo"
    exit 1
  fi

  # Main chat loop
  while true; do
    # Try reading an incoming message (non-blocking, 0.2s timeout)
    local msg=""
    if IFS= read -r -t 0.2 -u 3 msg 2>/dev/null; then
      [[ -z "$msg" ]] && continue
      printf '\n'   # Move off the current prompt line
      display_message "$msg"
      continue
    fi

    # No incoming message вЂ” read user input (with readline for history/arrows)
    printf '> '
    if ! IFS= read -r -e line; then
      # EOF / Ctrl-D в†’ quit
      break
    fi

    # Handle quit command
    if [[ "$line" == "/quit" ]]; then
      break
    fi

    # Send tagged line to remote via nc (fd 4)
    printf '[%s] %s\n' "$NAME" "$line" >&4
  done

  # Close FIFOs вЂ” nc gets EOF on its stdin and exits cleanly
  exec 3<&- 4>&- 2>/dev/null || true
  wait "$nc_pid" 2>/dev/null || true
  kill "$tunnel_pid" 2>/dev/null || true
  rm -f "$send_fifo" "$recv_fifo"
}

# в”Ђв”Ђ modes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
connect_client() {            # laptop в†’ box over ssh
  start_remote_listener
  ssh -N -L "${PORT}:127.0.0.1:${PORT}" "$HOST" &
  local TUNNEL=$!
  sleep 0.8
  echo "(connected to $HOST)"
  chat_loop "$PORT" "$TUNNEL"
}

connect_here() {              # on the box itself, no ssh
  start_local_listener
  echo "(local chat on $(hostname -s 2>/dev/null || echo this host))"
  chat_loop "$PORT"
}

say_once() {                  # one-shot push to the wall (works either side)
  if on_box; then
    printf '[%s] %s\n' "$NAME" "$*" >> "$WALL"
  else
    scp -q "$HELPER_SRC" "$HOST:.labchatd.sh" 2>/dev/null || true
    ssh "$HOST" 'cat >> ~/.labchat-wall' <<<"[$NAME] $*"
  fi
  echo "sent."
}

tail_once() {
  if on_box; then touch "$WALL"; tail -n 30 "$WALL"
  else ssh "$HOST" 'touch ~/.labchat-wall; tail -n 30 ~/.labchat-wall'; fi
}

status_listener() {
  if on_box; then
    ss -tlnH "sport = :$PORT" 2>/dev/null | grep -q LISTEN && echo "up on :$PORT (local)" || echo "down (local)"
  else
    ssh "$HOST" 'ss -tlnH "sport = :'"$PORT"'" 2>/dev/null | grep -q LISTEN && echo "up on :'"$PORT"' (remote)" || echo "down (remote)"'
  fi
}

stop_listener() {
  if on_box; then
    pkill -f "TCP-LISTEN:$PORT" >/dev/null 2>&1 && echo "listener stopped" || echo "no listener running"
  else
    ssh "$HOST" 'pkill -f "TCP-LISTEN:'"$PORT"'" >/dev/null 2>&1 && echo "listener stopped" || echo "no listener running"'
  fi
}

# on_box: true when we're running ON the box (set by `here`/`serve`).
ON_BOX="${ON_BOX:-0}"
on_box() { [ "$ON_BOX" = "1" ]; }

case "${1:-connect}" in
  connect|"") connect_client ;;
  here)       ON_BOX=1; connect_here ;;
  serve)      ON_BOX=1; start_local_listener ;;
  stop)       stop_listener ;;
  status)     status_listener ;;
  say)        shift; say_once "$@" ;;
  tail)       tail_once ;;
  -h|--help)  sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) echo "usage: labchat [connect|here|serve|stop|status|say \"text\"|tail]" >&2; exit 1 ;;
esac
